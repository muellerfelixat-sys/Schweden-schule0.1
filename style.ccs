html, body {
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #87CEEB;
}

body {
  display: flex;
  justify-content: center;
  align-items: center;
}

canvas {
  display: block;
  background: #87CEEB;
  border: 4px solid #005BAE;
  max-width: 100vw;
  max-height: 100vh;
}